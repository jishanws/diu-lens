APP_NAME=DIU Lens API
APP_VERSION=0.1.0
APP_ENV=production
ALLOWED_ORIGINS=https://www.diulens.app,https://diulens.app
DATABASE_URL=postgresql://diu_user:strongpassword@localhost:5432/diu_lens
JWT_SECRET=super_secret_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
FACE_MATCH_DISTANCE_THRESHOLD=0.38
FACE_MATCH_TOP_K=5
FACE_MATCH_CANDIDATE_POOL_LIMIT=200
INSIGHTFACE_MODEL_PACK=antelopev2
INSIGHTFACE_ROOT=/app/.insightface
ENROLLMENT_MIN_DETECTION_SCORE=0.55
ENROLLMENT_MIN_FACE_AREA_RATIO=0.09
ENROLLMENT_MAX_FACE_AREA_RATIO=0.35
ENROLLMENT_MAX_CENTER_OFFSET=0.24
ENROLLMENT_MIN_EDGE_MARGIN_RATIO=0.03
ENROLLMENT_MIN_BLUR_VARIANCE=45.0
ENROLLMENT_MIN_BRIGHTNESS=70.0
ENROLLMENT_MAX_BRIGHTNESS=200.0
ENROLLMENT_MIN_WIDTH=320
ENROLLMENT_MIN_HEIGHT=240
ENROLLMENT_REQUIRED_SAMPLES_PER_ANGLE=3
ENROLLMENT_STABILITY_DURATION_MS=650
ENROLLMENT_LIVENESS_CHALLENGE_COUNT=3
BIOMETRIC_STARTUP_VALIDATION=true
STORAGE_PATH=/var/lib/diu-lens/storage

# Bootstrap admin (auto-created on first startup if all three are set)
BOOTSTRAP_ADMIN_EMAIL=admin@diulens.app
BOOTSTRAP_ADMIN_PASSWORD=changeme
BOOTSTRAP_ADMIN_FULL_NAME=Admin
